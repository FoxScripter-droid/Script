-- Fake Dupe Logic
btn.MouseButton1Click:Connect(function()
    local char = player.Character
    if not char then return end
    local held = char:FindFirstChildOfClass("Tool")
    
    btn.Text = "DUPING..."
    btn.BackgroundColor3 = Color3.fromRGB(80, 80, 20)
    task.wait(1.2)
    
    if held then
        local itemName = held.Name
        local dupedCount = 0
        
        local pg = player:FindFirstChild("PlayerGui")
        if pg then
            local bpGui = pg:FindFirstChild("BackpackGui")
            if bpGui then
                for _, v in ipairs(bpGui:GetDescendants()) do
                    if v:IsA("TextLabel") and v.Name == "ToolName" and string.find(v.Text:lower(), itemName:lower()) then
                        local slot = v.Parent
                        if slot then
                            local countLabel = slot:FindFirstChild("ToolCount")
                            if countLabel then
                                local text = countLabel.Text
                                
                                if text:match("^x%d+$") then
                                    local num = tonumber(text:match("%d+"))
                                    countLabel.Text = "x" .. tostring(num * 2)
                                    dupedCount = dupedCount + 1
                                    
                                elseif text:match("^[%d%.]+%s*kg$") then
                                    local num = tonumber(text:match("[%d%.]+"))
                                    countLabel.Text = string.format("%.2fkg", num * 2)
                                    dupedCount = dupedCount + 1
                                    
                                elseif text == "" then
                                    countLabel.Text = "x2"
                                    dupedCount = dupedCount + 1
                                end
                                
                                local flash = Instance.new("Frame")
                                flash.Size = UDim2.new(1,0,1,0)
                                flash.BackgroundColor3 = Color3.fromRGB(255, 255, 100)
                                flash.BackgroundTransparency = 0.2
                                flash.BorderSizePixel = 0
                                flash.ZIndex = 10
                                flash.Parent = slot
                                
                                local tween = game:GetService("TweenService"):Create(flash, TweenInfo.new(0.5), {BackgroundTransparency = 1})
                                tween:Play()
                                tween.Completed:Connect(function() flash:Destroy() end)
                            end
                        end
                    end
                end
            end
        end
        
        if dupedCount > 0 then
            playSound()
            btn.Text = "SUCCESS! (Doubled)"
            btn.BackgroundColor3 = Color3.fromRGB(20, 80, 20)
        else
            btn.Text = "UI NOT FOUND"
            btn.BackgroundColor3 = Color3.fromRGB(80, 20, 20)
        end
    else
        btn.Text = "NOTHING HELD!"
        btn.BackgroundColor3 = Color3.fromRGB(80, 20, 20)
    end
    
    task.wait(2)
    btn.Text = "DUPE EQUIPPED ITEM"
    btn.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
end)
